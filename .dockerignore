backend/**/lerna-debug.log*

backend/**/node_modules
backend/**/dist
backend/**/dist-ssr
backend/**/*.local

# Editor directories and files
backend/**/.vscode/*
!backend/**/.vscode/extensions.json
backend/**/.idea
backend/**/.DS_Store
backend/**/*.suo
backend/**/*.ntvs*
backend/**/*.njsproj
backend/**/*.sln
backend/**/*.sw?

